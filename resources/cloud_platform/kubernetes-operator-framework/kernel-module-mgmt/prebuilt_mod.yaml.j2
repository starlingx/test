apiVersion: kmm.sigs.x-k8s.io/v1beta1
kind: Module
metadata:
  name: kmm-prebuilt
  namespace: kernel-module-management
spec:
  moduleLoader:
    container:
      modprobe:
        moduleName: hello_world_dmesg
      kernelMappings:
        - literal: "{{ kernel_version }}-amd64"
          containerImage: {{ kmm_container_image_registry }}:amd64-hw
          registryTLS:
            insecure: false
            insecureSkipTLSVerify: true
 
        - literal: "{{ kernel_version }}-rt-amd64"
          containerImage: {{ kmm_container_image_registry }}:rt-amd64-hw
          registryTLS:
            insecure: false
            insecureSkipTLSVerify: true
 
  imageRepoSecret:
    name: "kmm-registry-secret"
 
  selector:
    kubernetes.io/os: linux
 
  tolerations:
    - key: "services"
      operator: "Equal"
      value: "disabled"
      effect: "NoExecute"
