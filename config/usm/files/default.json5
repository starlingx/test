{
  // Default USM Configuration
  // This file contains default settings for USM upgrade and patch operations

  // Type of operation: "upgrade" or "patch"
  "usm_operation_type": "upgrade",

  // Software release paths
  "iso_path": "/opt/software/starlingx.iso",
  "sig_path": "/opt/software/starlingx.sig", 
  "patch_path": ["/opt/software/starlingx-10.0.1.patch", "/opt/software/starlingx-10.0.2.patch"],

  // License
  "license_from_path": "",
  "license_to_path": "",
  "license_server": "",
  "license_server_username": "",
  "license_server_password": "",

  
  // Target release configuration
  "to_release_ids": ["starlingx-10.0.1","starlingx-10.0.2"],

  // Whether a reboot is required after the operation
  "requires_reboot": false,

  // Operation type flags
  "snapshot": false,
  "rollback": false,
  "deploy_delete": true,
  "record_kpi": false,

  // Optional CLI arguments passed to the 'software upload' or 'software upgrade' command
  // Example: "--force"
  "upgrade_arguments": "",

  // Timeout configurations (in seconds)
  "upload_patch_timeout_sec": 6000,
  "upload_release_timeout_sec": 6000,
  "upload_poll_interval_sec": 30,
  "deployment_timeout_sec": 9000,
  "activation_timeout_sec": 3600,
  "precheck_timeout_sec": 300,
  "software_delete_timeout_sec": 300,
  "deploy_delete_timeout_sec": 300,
  "deploy_start_timeout_sec": 1200,
  "deploy_host_timeout_sec": 1800,
  "deploy_complete_timeout_sec": 900,

  // Remote copy settings
  "copy_from_remote": true,
  "remote_server": "",
  "remote_username": "",
  "remote_password": "",
  "dest_dir": "/scratch/usm_files/",

  // Distributed Cloud
  "subcloud_group": "Default",
  "subcloud_name": "None",
  "max_parallel_subclouds": 10,

  // Pre-upgrade setup
  "docker_fs_size": 60,
  "docker_distribution_fs_size": 60,

  // Alarms to ignore during cleanup
  "cleanup_ignore_alarms": ["900.020", "900.022", "900.023", "900.024", "280.002"],

  // Alarm restriction level for VIM orchestration strategy creation
  // Valid options: "strict", "relaxed", "permissive", or "" (empty = use VIM default)
  "alarm_restrictions": "",

  // Combined Platform & Kubernetes upgrade
  // When true, VIM strategy create will pass --kube-upgrade=<target_k8s_version>
  // The target K8s version is read from kubernetes_upgrade_config.json5
  "combined_upgrade": false,

  // Metapackage deployment configuration
  // Controls which metapackages are deployed during an upgrade.
  // - "None": skip metapackage deployment entirely
  // - "All": deploy all metapackages in the 'available' state from to_release_ids
  // - ["base_11.00.0", "infra_11.00.0"]: deploy only the listed metapackages (as example)
  "metapackages": "None",

  // Test patches configuration for per-test patch resolution
  // Each test case resolves its patch path using: <base_dir>/<prefix>-<suffix>.patch
  "test_patches": {
    "base_dir": "",
    "prefix": "",
    "single_release_id": "",
    "dependent_prefix": "",
    "dependent_patches": []
  },
  // Backup comparison settings
  // baseline_backup_path: path to the baseline backup tar/tgz (required for comparison)
  // target_backup_path: path to the target backup tar/tgz (if empty, uses --running_system mode)
  // backup_compare_args: additional CLI args for backup-compare.py (e.g., "--running_system --cache")
  // backup_compare_exclude_file: path to the yml file with files to be excluded from the comparison
  "baseline_backup_path": "",
  "target_backup_path": "",
  "backup_compare_args": "",
  "backup_compare_exclude_file": ""
}
