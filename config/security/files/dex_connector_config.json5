{
    "dex_connector": {
        "oidc_app_name": "oidc-auth-apps",
        "namespace": "kube-system",
        "working_dir": "/home/sysadmin/dex-attr-test/",
        "apply_timeout": 300,
        "local_ldap": {
            "email_attr": "mail",
            "username_attr": "uid",
            "name_attr": "gecos"
        },
        "oidc_username_claim": {
            "default": "preferred_username",
            "alternative": "email"
        },
        "test_user": {
            "username": "dex-attr-testuser",
            "password": "Test@12345",
            "email": "dex-attr-testuser@local.domain",
            "role": "admin",
            "crb_name": "dex-attr-test-crb"
        }
    }
}
