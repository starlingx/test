{
    // dns name for the lab
    "domain_name": "lab_domain_name",

    // ACME server url
    "stepca_server_url": "external_acme_server_url",

    // ACME server issuer
    "stepca_server_issuer": "external_acme_server_issuer",

    // Nginx ingress configuration
    "nginx_ingress": {
        "https_test": {
            "host_name": "konoha.rei",
            "key_file": "key.crt",
            "cert_file": "cert.crt",
            "tls_secret_name": "kanoha-secret",
            "namespace": "pvtest"
        },
        "http_test": {
            "namespace": "pvtest"
        },
        "external_ca_test": {
            "stepca_issuer": "stepca-issuer",
            "pod_name": "kuard",
            "cert": "kuard-ingress-tls",
            "deploy_app_file_name": "deploy_app.yaml",
            "global_policy_file_name": "global_policy.yaml",
            "kuard_file_name": "kuard.yaml",
            "namespace": "pvtest",
            "tls_secret_name": "kuard-ingress-tls"
        }
    },

    // Portieris configuration
    "portieris": {
        "registry_server_hostname": "registry_server_hostname",
        "registry_server_port": "registry_server_port",
        "trust_server": "https://registry_server_hostname:trust_port",
        "signed_image_name": "registry_server_hostname:registry_server_port/signed_repo/image:tag",
        "unsigned_image_name": "registry_server_hostname:registry_server_port/unsigned_repo/image:tag",
        "registry_credentials": {
            "username": "registry_username",
            "password": "registry_password"
        },
        "registry_ca_cert": "registry_ca_cert"
    },

    // OIDC with Keycloak and MFA configuration
    "oidc_keycloak": {
        // Working directory on the remote host for OIDC files
        "working_dir": "/home/sysadmin/oidc-keycloak/",

        // Home directory of the remote user (used to build paths like working_dir and token cache)
        "remote_user_home": "/home/sysadmin",

        // Kubernetes namespace for OIDC secrets
        "namespace": "kube-system",

        // Name of the upstream IdP CA secret
        "upstream_idp_ca_secret_name": "oidc-upstream-idp-ca",

        // Filename used as the key inside the secret (matches --from-file key)
        "upstream_idp_ca_filename": "upstream-ca.crt",

        // Keycloak OIDC client ID
        "client_id": "keycloak_oidc_client_id",

        // Keycloak OIDC client secret
        "client_secret": "keycloak_oidc_client_secret",

        // Keycloak realm issuer URL
        "external_idp_issuer_url": "https://keycloak_host/realms/keycloak_realm",

        // Name of the OIDC auth apps TLS certificate secret
        "oidc_auth_apps_certificate_secret_name": "oidc-auth-apps-certificate",

        // ClusterRoleBinding configuration
        "cluster_role_binding": {
            "binding_name": "crb_binding_name",
            "cluster_role": "cluster-admin",
            "group": "crb_group"
        },

        // system-local-ca certificate filename saved alongside the kubeconfig
        "system_local_ca_cert_filename": "system-local-ca.crt",

        // Local OIDC login kubeconfig filename
        "kubeconfig_filename": "local-oidc-login-kubeconfig.yml",

        // OIDC login browser URL port
        "oidc_login_port": 8000,

        // Invalid issuer URL used in negative authentication tests
        "invalid_issuer_url": "https://invalid-issuer.example.com/realms/nonexistent",

        // Keycloak admin credentials for test lifecycle management
        "admin": {
            "username": "keycloak_admin_username",
            "password": "keycloak_admin_password"
        },

        // Keycloak test user credentials for OIDC authentication
        "test_user": {
            "username": "keycloak_test_username",
            "password": "keycloak_test_password",
            "totp_secret": "keycloak_test_totp_secret"
        },

        // Keycloak guard user credentials for RBAC no-resource tests
        "guard_user": {
            "username": "keycloak_guard_username",
            "password": "keycloak_guard_password",
            "totp_secret": "keycloak_guard_totp_secret"
        },

        // Guard ClusterRole and ClusterRoleBinding configuration
        "guard_rbac": {
            "cluster_role_name": "cluster-guard",
            "binding_name": "wrcp-guard-binding",
            "group": "/wrcp-guard"
        },

        // Keycloak operator user credentials for RBAC operator role tests
        "operator_user": {
            "username": "keycloak_operator_username",
            "password": "keycloak_operator_password",
            "totp_secret": "keycloak_operator_totp_secret"
        },

        // Operator ClusterRole and ClusterRoleBinding configuration
        "operator_rbac": {
            "cluster_role_name": "cluster-operator",
            "binding_name": "wrcp-operator-binding",
            "group": "/wrcp-operator"
        },

        // Keycloak OIDC connector ID
        "connector_id": "keycloak",

        // DEX callback redirect URI
        "redirect_uri": "https://oam_ip:dex_callback_port/dex/callback",

        // Static OIDC client configuration
        "static_client": {
            "id": "stx-oidc-client-app",
            "name": "STX OIDC Client app",
            "secret": "oidc_static_client_secret",
            "redirect_uris": [
                "http://localhost:8000",
                "http://oam_ip:oidc_login_port",
                "https://oam_ip:oidc_client_port/callback"
            ]
        },

        // Keycloak CA certificate (PEM encoded)
        "keycloak_ca_cert": "keycloak_ca_cert_pem"
    }
}
